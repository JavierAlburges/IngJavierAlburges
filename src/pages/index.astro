  "@graph": [
    {
      "@type": "Person",
      "@id": "https://javieralburges.vercel.app/#person",
      name: "Javier Alburges",
      alternateName: "Ing. Javier Alburges",
      jobTitle: "Fundador & CEO en GearSoftCA · Supervisor de Operaciones / Scrum Master",
      description: "Fundador y CEO de GearSoftCA. Ingeniero mecánico, desarrollador de software y especialista en IA con más de 5 años de experiencia en soluciones tecnológicas para empresas.",
      url: "https://javieralburges.vercel.app",
      image: "https://javieralburges.vercel.app/javier.png",
      email: "javieralburges@gmail.com",
      telephone: "+584127521730",
      address: {
        "@type": "PostalAddress",
        addressLocality: "Maracaibo",
        addressRegion: "Zulia",
        addressCountry: "VE",
      },
      sameAs: [
        "https://www.linkedin.com/in/javieralburges/",
        "https://github.com/JavierAlburges/",
        "https://gearsoftca.vercel.app",
        "https://www.linkedin.com/company/gearsoftca/",
      ],
      worksFor: {
        "@type": "Organization",
        "@id": "https://javieralburges.vercel.app/#gearsoftca",
        name: "GearSoftCA",
        url: "https://gearsoftca.vercel.app",
        logo: "https://javieralburges.vercel.app/logo-512.png",
        description: "Empresa líder en desarrollo de software en Maracaibo, Zulia, Venezuela. Software a medida, desarrollo web y móvil, Google Cloud, Odoo ERP/CRM, automatización con IA.",
        address: {
          "@type": "PostalAddress",
          addressLocality: "Maracaibo",
          addressRegion: "Zulia",
          addressCountry: "VE",
        },
        sameAs: [
          "https://www.linkedin.com/company/gearsoftca/",
          "https://gearsoftca.vercel.app",
        ],
      },
      alumniOf: {
        "@type": "EducationalOrganization",
        name: "Universidad del Zulia",
      },
      knowsAbout: [
        "Desarrollo de software",
        "React Native",
        "Next.js",
        "Kotlin",
        "Firebase",
        "Inteligencia Artificial",
        "Odoo ERP",
        "Scrum",
        "ISO 9001:2015",
        "Gerencia de proyectos",
        "E-commerce",
        "Transformación digital",
      ],
      hasCredential: [
        {
          "@type": "EducationalOccupationalCredential",
          credentialCategory: "certification",
          name: "Auditor Interno ISO 9001:2015",
        },
      ],
    },
    {
      "@type": "WebSite",
      "@id": "https://javieralburges.vercel.app/#website",
      url: "https://javieralburges.vercel.app",
      name: "Javier Alburges - GearSoftCA",
      description: "Portafolio profesional de Javier Alburges, Fundador & CEO de GearSoftCA",
      publisher: { "@id": "https://javieralburges.vercel.app/#person" },
      inLanguage: "es",
    },
    {
      "@type": "WebPage",
      "@id": "https://javieralburges.vercel.app/#webpage",
      url: "https://javieralburges.vercel.app",
      name: "Javier Alburges | Ingeniero, CEO de GearSoftCA, Desarrollador de Software y Especialista en IA",
      isPartOf: { "@id": "https://javieralburges.vercel.app/#website" },
      about: { "@id": "https://javieralburges.vercel.app/#person" },
      inLanguage: "es",
    },
    {
      "@type": "Organization",
      "@id": "https://javieralburges.vercel.app/#gearsoftca",
      name: "GearSoftCA",
      alternateName: "GearSoft CA",
      url: "https://gearsoftca.vercel.app",
      founder: { "@id": "https://javieralburges.vercel.app/#person" },
      foundingDate: "2020-09",
      description: "Empresa de desarrollo de software en Maracaibo, Venezuela. Especialista en desarrollo web, apps móviles, Odoo ERP, inteligencia artificial y soluciones digitales para empresas en Venezuela y Latinoamérica.",
      areaServed: ["Venezuela", "Latinoamérica", "LATAM"],
      knowsAbout: [
        "Desarrollo de software a medida",
        "Aplicaciones móviles",
        "Desarrollo web",
        "Odoo ERP/CRM",
        "Inteligencia Artificial",
        "Google Cloud",
        "E-commerce",
      ],
      sameAs: [
        "https://www.linkedin.com/company/gearsoftca/",
        "https://gearsoftca.vercel.app",
      ],
    },
  ],
