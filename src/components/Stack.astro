---
const TECH = [
  {
    category: "Mobile",
    items: [
      { name: "Kotlin", icon: "/tecnologias/kotlin.png" },
      { name: "React Native", icon: "/tecnologias/react-native.png" },
      { name: "Flutter", icon: "/tecnologias/flutter.png" },
      { name: "Dart", icon: "/tecnologias/dart.png" },
      { name: "Android", icon: "/tecnologias/android.png" },
      { name: "iOS", icon: "/tecnologias/ios.png" },
    ],
  },
  {
    category: "Web & Frontend",
    items: [
      { name: "React", icon: "/tecnologias/react.png" },
      { name: "Next.js", icon: "/tecnologias/next-js.png" },
      { name: "JavaScript", icon: "/tecnologias/javascript.png" },
      { name: "TypeScript", icon: "/tecnologias/typescript.png" },
    ],
  },
  {
    category: "Backend & Data",
    items: [
      { name: "NestJS", icon: "/tecnologias/nestjs.png" },
      { name: "PostgreSQL", icon: "/tecnologias/postgre-sql.png" },
      { name: "SQLite", icon: "/tecnologias/sqlite.png" },
      { name: "Firebase", icon: "/tecnologias/firebase.png" },
      { name: "Supabase", icon: "/tecnologias/supabase.png" },
    ],
  },
  {
    category: "Diseño & Herramientas",
    items: [
      { name: "Figma", icon: "/tecnologias/figma.png" },
      { name: "Canva", icon: "/tecnologias/canva.png" },
      { name: "Jira", icon: "/herramientas/jira.png" },
      { name: "Google Workspace", icon: "/herramientas/google-workspace.png" },
    ],
  },
  {
    category: "Metodologías & IA",
    items: [
      { name: "Scrum", icon: "/herramientas/scrum.png", label: "Scrum" },
      { name: "PMI", icon: "/herramientas/pmi.png", label: "PMI" },
      { name: "Gemini", icon: "/herramientas/gemini.png", label: "IA" },
    ],
  },
];
---

<div class="flex flex-col gap-y-10">
  {
    TECH.map(({ category, items }) => (
      <div class="flex flex-col gap-y-4">
        <h3 class="text-xl font-semibold text-gray-800 dark:text-gray-200 opacity-80">
          {category}
        </h3>
        <div class="flex flex-wrap gap-4">
          {items.map((item) => (
            <div 
              class="flex items-center gap-x-2 p-2 rounded-xl border border-gray-200 dark:border-gray-800 bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm transition-all hover:scale-105 hover:bg-white dark:hover:bg-gray-800"
              title={item.name}
            >
              <img 
                src={item.icon} 
                alt={item.name} 
                class="size-8 object-contain" 
                loading="lazy"
              />
              <span class="text-sm font-medium text-gray-700 dark:text-gray-300">
                {item.label || item.name}
              </span>
            </div>
          ))}
        </div>
      </div>
    ))
  }
</div>
