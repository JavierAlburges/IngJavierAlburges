---
const currentYear = new Date().getFullYear()
---

<footer
  class="opacity-90 m-4 mt-16 w-full mx-auto container lg:max-w-4xl md:max-w-2xl mb-10"
>
  <div
    class="rounded-2xl w-full max-w-screen-xl mx-auto py-6 px-4 border border-gray-200/10 dark:border-gray-700/30 bg-white/5 dark:bg-gray-900/30 backdrop-blur-sm"
  >
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
      <div class="flex flex-col gap-1">
        <span class="text-sm font-semibold text-gray-800 dark:text-gray-100">
          Ing. Javier Alburges · <a target="_blank" href="https://gearsoftca.vercel.app" class="text-yellow-500 hover:text-yellow-400 transition hover:underline">GearSoftCA</a>
        </span>
        <span class="text-xs text-zinc-500 dark:text-zinc-400">
          © {currentYear} Todos los derechos reservados · Maracaibo, Venezuela
        </span>
      </div>
      <ul
        class="flex flex-wrap items-center gap-4 text-sm font-medium dark:text-white/80"
      >
        <li>
          <a
            target="_blank"
            href="https://www.linkedin.com/in/javieralburges/"
            class="hover:text-yellow-500 transition hover:underline"
            aria-label="LinkedIn de Javier Alburges"
          >LinkedIn</a>
        </li>
        <li>
          <a
            target="_blank"
            href="https://github.com/JavierAlburges/"
            class="hover:text-yellow-500 transition hover:underline"
            aria-label="GitHub de Javier Alburges"
          >GitHub</a>
        </li>
        <li>
          <a
            target="_blank"
            href="https://wa.me/584127521730"
            class="hover:text-yellow-500 transition hover:underline"
            aria-label="WhatsApp de Javier Alburges"
          >WhatsApp</a>
        </li>
        <li>
          <a
            id="contacto"
            href="mailto:javieralburges@gmail.com"
            class="hover:text-yellow-500 transition hover:underline"
            aria-label="Email de Javier Alburges"
          >Contacto</a>
        </li>
      </ul>
    </div>
  </div>
</footer>
